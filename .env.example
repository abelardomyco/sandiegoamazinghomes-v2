# Copy to .env.local and fill in values.
# Production: canonical URLs, Open Graph, sitemap, robots, JSON-LD (no trailing slash).
# NEXT_PUBLIC_SITE_URL=https://sandiegoamazinghomes.com
# Supabase: Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: service role for server-side writes (listing cache, market stats, agent_runs)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Mapbox: https://account.mapbox.com/access-tokens/ (for /homes and /map)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token
# RentCast (Phase 1): listings — free developer tier; add to .env.local
# RENTCAST_API_KEY=your-rentcast-key
# Optional: RENTCAST_BASE_URL=https://api.rentcast.io/v1
# Phase 2+: market data
# REDFIN_API_KEY=
# ZILLOW_API_KEY=
# Admin dashboard (/admin) — set both for production; keep secret.
# ADMIN_DASHBOARD_PASSWORD=
# ADMIN_SESSION_SECRET=
# Privacy-friendly analytics (optional): https://plausible.io — no cookie banner required in many jurisdictions.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sandiegoamazinghomes.com

# Optional: npm run sync:instagram — downloads @sandiegoamazinghomes media into public/images/sdah photos to use/
# (backup / asset sync only; homepage Instagram is a link-out, not an embedded feed.)
